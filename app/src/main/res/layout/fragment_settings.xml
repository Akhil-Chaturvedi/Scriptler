<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color"
    android:scrollbars="none"
    tools:context=".SettingsFragment"> <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Appearance"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_color"
            android:layout_marginBottom="16dp" /> <LinearLayout
            android:id="@+id/setting_item_dark_theme"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/card_background" android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <FrameLayout
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/icon_background" android:layout_marginRight="12dp">
                    <ImageView
                        android:id="@+id/icon_theme"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_moon" app:tint="@color/primary_color" /> </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dark Theme"
                    android:textSize="16sp"
                    android:textColor="@color/text_color" />

            </LinearLayout>

            <Switch
                android:id="@+id/switch_dark_theme"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="@color/text_color"
                android:trackTint="@color/switch_track_selector" /> </LinearLayout>

        <LinearLayout
            android:id="@+id/setting_item_font_size"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <FrameLayout
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/icon_background"
                    android:layout_marginRight="12dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_type" app:tint="@color/primary_color" /> </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Editor Font Size"
                    android:textSize="16sp"
                    android:textColor="@color/text_color" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageButton
                    android:id="@+id/button_font_size_decrease"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/button_circle_background" android:src="@drawable/ic_minus" app:tint="@color/text_color" /> <TextView
                    android:id="@+id/text_font_size_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="14" android:textSize="16sp"
                    android:textColor="@color/text_color"
                    android:layout_marginHorizontal="12dp"
                    android:minWidth="24dp"
                    android:gravity="center" />

                <ImageButton
                    android:id="@+id/button_font_size_increase"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/button_circle_background"
                    android:src="@drawable/ic_plus" app:tint="@color/text_color" /> </LinearLayout>

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Editor"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_color"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:id="@+id/setting_item_auto_save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <FrameLayout
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/icon_background"
                    android:layout_marginRight="12dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_save" app:tint="@color/primary_color" /> </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Auto Save"
                    android:textSize="16sp"
                    android:textColor="@color/text_color" />

            </LinearLayout>

            <Switch
                android:id="@+id/switch_auto_save"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="@color/text_color"
                android:trackTint="@color/switch_track_selector" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Notifications"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_color"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:id="@+id/setting_item_notifications"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <FrameLayout
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/icon_background"
                    android:layout_marginRight="12dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_bell" app:tint="@color/primary_color" /> </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enable Notifications"
                    android:textSize="16sp"
                    android:textColor="@color/text_color" />

            </LinearLayout>

            <Switch
                android:id="@+id/switch_notifications_enabled"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="@color/text_color"
                android:trackTint="@color/switch_track_selector" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="About"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_color"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:id="@+id/about_item_scriptler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <FrameLayout
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/icon_background"
                    android:layout_marginRight="12dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_info" app:tint="@color/primary_color" /> </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Scriptler"
                    android:textSize="16sp"
                    android:textColor="@color/text_color" />

            </LinearLayout>

            <TextView
                android:id="@+id/text_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v1.0.0" android:textSize="14sp"
                android:textColor="@color/text_secondary_color" /> </LinearLayout>
<LinearLayout
    android:id="@+id/about_item_github"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/card_background"
    android:padding="16dp"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <FrameLayout
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/icon_background"
            android:layout_marginRight="12dp">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_github"
                app:tint="@color/primary_color" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GitHub"
            android:textSize="16sp"
            android:textColor="@color/text_color" />

    </LinearLayout>

    <TextView
        android:id="@+id/text_github_link"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="scriptler"
        android:textSize="14sp"
        android:textColor="@color/primary_color" />

</LinearLayout>

<!-- Storage section -->
<TextView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:text="Storage"
    android:textSize="18sp"
    android:textStyle="bold"
    android:textColor="@color/text_color"
    android:layout_marginTop="12dp"
    android:layout_marginBottom="16dp" />

<LinearLayout
    android:id="@+id/setting_item_storage_info"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/card_background"
    android:padding="16dp"
    android:layout_marginBottom="12dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <FrameLayout
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/icon_background"
            android:layout_marginRight="12dp">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_package"
                app:tint="@color/primary_color" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Package Cache"
                android:textSize="16sp"
                android:textColor="@color/text_color" />

            <TextView
                android:id="@+id/text_package_cache_size"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Calculating…"
                android:textSize="12sp"
                android:textColor="@color/text_secondary_color" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>

<LinearLayout
    android:id="@+id/setting_item_clear_cache"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/card_background"
    android:padding="16dp"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <FrameLayout
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/icon_background"
            android:layout_marginRight="12dp">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_trash"
                app:tint="@color/error_color" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Clear Package Cache"
            android:textSize="16sp"
            android:textColor="@color/error_color" />

    </LinearLayout>

</LinearLayout>

<LinearLayout
    android:id="@+id/setting_item_storage_location"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/card_background"
    android:padding="16dp"
    android:layout_marginBottom="12dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <FrameLayout
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/icon_background"
            android:layout_marginRight="12dp">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_info"
                app:tint="@color/primary_color" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Script Storage Location"
                android:textSize="16sp"
                android:textColor="@color/text_color" />

            <TextView
                android:id="@+id/text_storage_location"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Documents/Scriptler/"
                android:textSize="12sp"
                android:textColor="@color/text_secondary_color" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>

</LinearLayout>

</ScrollView>
