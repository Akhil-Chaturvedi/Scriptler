<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme (Dark) -->
    <style name="Base.Theme.Scriptler" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary_color</item>
        <item name="colorPrimaryDark">@color/primary_dark_color</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/card_color</item>
        <item name="colorOnSurface">@color/text_color</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary_color</item>
        <item name="android:colorBackground">@color/background_color</item>
        <item name="android:statusBarColor">@color/background_color</item>
        <item name="android:navigationBarColor">@color/background_color</item>
        <item name="android:windowBackground">@color/background_color</item>
    </style>

    <style name="Theme.Scriptler" parent="Base.Theme.Scriptler" />

    <!-- Light theme variant -->
    <style name="Theme.Scriptler.Light" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary_color</item>
        <item name="colorPrimaryDark">@color/primary_dark_color</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/light_card_color</item>
        <item name="colorOnSurface">@color/light_text_color</item>
        <item name="colorOnSurfaceVariant">@color/light_text_secondary_color</item>
        <item name="android:colorBackground">@color/light_background_color</item>
        <item name="android:statusBarColor">@color/light_background_color</item>
        <item name="android:navigationBarColor">@color/light_background_color</item>
        <item name="android:windowBackground">@color/light_background_color</item>
    </style>
</resources>
